# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- PostgreSQL ---
POSTGRES_DB=hapi
POSTGRES_USER=hapi_admin
# Generate a strong one: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME

# --- Cloudflare Tunnel (used by scripts, not by docker-compose) ---
# The public hostname you will route to this server, e.g. fhir.yourdomain.com
TUNNEL_HOSTNAME=fhir.example.com
TUNNEL_NAME=mac-fhir-tunnel
