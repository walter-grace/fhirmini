# Copy to .env and fill in. .env is gitignored — never commit real values.
# `scripts/bootstrap.sh` creates this automatically with a generated password.

# --- PostgreSQL (native, Homebrew) ---
POSTGRES_DB=hapi
POSTGRES_USER=hapi_admin
# Generate a strong one: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME
PGHOST=127.0.0.1
PGPORT=5432

# --- AI layer ---
# local = MLX on-device (PHI-safe, default).  openrouter = cloud (DEV/synthetic ONLY).
AI_BACKEND=local
PHASE=dev-sandbox
FHIR_BASE=http://127.0.0.1:8080/fhir
AI_LOCAL_LLM=mlx-community/Qwen2.5-VL-7B-Instruct-4bit
AI_LOCAL_LLM_URL=http://127.0.0.1:8081/v1
AI_EMBED_MODEL=mlx-community/bge-small-en-v1.5-bf16
AI_PORT=8090
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Integration engine ---
ENGINE_PORT=8088

# --- Cloudflare Tunnel (used by scripts/setup-tunnel.sh) ---
TUNNEL_HOSTNAME=fhir.example.com
TUNNEL_NAME=fhirmini-tunnel
